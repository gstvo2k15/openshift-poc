pipeline {
    agent {
        label 'openshift-agent'
    }

    parameters {
        choice(
            name: 'ENVIRONMENT',
            choices: ['dev', 'tst', 'acc', 'prod'],
            description: 'Environment'
        )

        choice(
            name: 'ACTION',
            choices: ['deploy', 'dashboards', 'remove'],
            description: 'Action'
        )
    }

    environment {
        OPENSHIFT_API_URL = credentials('openshift-api-url')
    }

    stages {
        stage('Checkout') {
            steps {
                checkout scm
            }
        }

        stage('Login OpenShift') {
            steps {
                withCredentials([
                    string(
                        credentialsId: 'openshift-service-account-token',
                        variable: 'OPENSHIFT_TOKEN'
                    )
                ]) {
                    sh '''
                        set -euo pipefail

                        oc login "${OPENSHIFT_API_URL}" \
                          --token="${OPENSHIFT_TOKEN}"
                    '''
                }
            }
        }

        stage('Deploy') {
            when {
                expression {
                    params.ACTION == 'deploy'
                }
            }

            steps {
                sh 'scripts/deploy.sh "${ENVIRONMENT}"'
            }
        }

        stage('Deploy dashboards') {
            when {
                expression {
                    params.ACTION == 'dashboards'
                }
            }

            steps {
                sh 'scripts/deploy-dashboards.sh "${ENVIRONMENT}"'
            }
        }

        stage('Remove') {
            when {
                expression {
                    params.ACTION == 'remove'
                }
            }

            steps {
                sh 'scripts/remove.sh "${ENVIRONMENT}"'
            }
        }
    }

    post {
        always {
            sh 'oc logout || true'
        }
    }
}